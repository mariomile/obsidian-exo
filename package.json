{
	"name": "obsidian-exo",
	"version": "0.22.2",
	"description": "Exo — an agentic AI assistant in your Obsidian sidebar, powered by the Claude or Codex CLI, with a custom theme-aware chat UI.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"lint": "eslint src tests",
		"test": "vitest run",
		"smoke": "node scripts/smoke.mjs",
		"bump": "node scripts/bump.mjs"
	},
	"keywords": [
		"obsidian",
		"claude",
		"codex",
		"ai",
		"agent"
	],
	"author": "Mario Miletta",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.39.4",
		"obsidian": "latest",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.62.1",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.3.195",
		"zod": "^4.4.3"
	}
}
